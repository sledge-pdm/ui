{
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "jsxImportSource": "solid-js",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "preserve"
  }
}
